{
  "name": "switchboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "env:check": "tsx scripts/env-check.ts",
    "preflight": "tsx scripts/preflight.ts",
    "seed": "tsx scripts/seed.ts",
    "telegram:run": "tsx scripts/run-telegram.ts",
    "telegram:discover": "tsx scripts/telegram-discover.ts",
    "dashboard:dev": "vite --config dashboard/vite.config.ts",
    "dashboard:build": "vite build --config dashboard/vite.config.ts",
    "dashboard:deploy": "npm run dashboard:build && npx wrangler pages deploy dashboard/dist --project-name \"${CLOUDFLARE_PROJECT_NAME:-switchboard}\"",
    "convex:deploy": "npx convex deploy --typecheck enable"
  },
  "dependencies": {
    "convex": "^1.25.4",
    "dotenv": "^16.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  }
}
